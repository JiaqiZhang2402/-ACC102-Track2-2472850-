import pandas as pd
import matplotlib.pyplot as plt
import yfinance as yf

# Download official AAPL 2023 full-year stock raw data
data = yf.download("AAPL", start="2023-01-01", end="2024-01-01")

# Preview first 5 rows complete original dataset
print(data.head())

# Draw standard official closing price trend line chart required by assignment
plt.figure(figsize=(12,5))
plt.plot(data['Close'], label='AAPL Daily Closing Price USD')
plt.title('Apple Inc. Daily Closing Stock Price Trend 2023 Full Year')
plt.xlabel('Trading Date')
plt.ylabel('Daily Closing Price Unit: USD')
plt.legend()
plt.show()

# Required core descriptive financial statistical analysis output data
print('2023 Annual Highest Closing Price:', data['Close'].max())
print('2023 Annual Lowest Closing Price:', data['Close'].min())
print('2023 Annual Average Daily Closing Price:', round(data['Close'].mean(),2))
